{
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/analyze/route.ts": {
      "maxDuration": 300
    },
    "app/api/mcp/route.ts": {
      "maxDuration": 300
    },
    "app/api/audit/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/indexnow",
      "schedule": "0 6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}