# =============================================================================
# Revel — environment variables (copy to .env.local, then to Vercel)
# =============================================================================
# Local dev:  NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://tryrevel.xyz  (https:// required on Vercel)
# Note: bare domains like tryrevel.xyz are auto-normalized to https:// at build time
# =============================================================================

# --- Site URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Marketing apex used for logo home from docs/legal/auth subdomains
# Production: NEXT_PUBLIC_MARKETING_URL=https://tryrevel.xyz
# Falls back to NEXT_PUBLIC_APP_URL when unset
NEXT_PUBLIC_MARKETING_URL=
NEXT_PUBLIC_ENABLE_SUBDOMAIN_REDIRECTS=false
NEXT_PUBLIC_DOCS_URL=https://docs.tryrevel.xyz
NEXT_PUBLIC_LEGAL_URL=https://legal.tryrevel.xyz
NEXT_PUBLIC_AUTH_URL=https://auth.tryrevel.xyz

# --- Analysis providers (cascade on error / quota / incomplete report) ---
# Default order: Groq → OpenRouter → Gemini (Gemini last — small free quota)
# Pin first: groq | openrouter | gemini | auto
ANALYSIS_PROVIDER=auto
# auto = agentic when Groq/Gemini key set; legacy = OpenRouter single-shot only
ANALYSIS_MODE=auto
# Each agentic step = 1 API call (homepage + pages + submit)
AGENT_MAX_STEPS=10

# 1) Groq (recommended first): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional extra Groq models. Do not use llama-4-scout on free/dev tier.
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# 2) OpenRouter (second / reliable single-shot): https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Prefer a strong paid model; free models are rate-limited and more generic
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_MODEL_FALLBACK=google/gemini-2.5-flash,qwen/qwen3-next-80b-a3b-instruct:free

# 3) Gemini last (tight free quota): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemini-2.5-flash-lite

# --- Revel MCP / A2MCP (Phase 3 — NEW) ---
# Bearer token for remote MCP clients (Cursor HTTP, OKX.AI listing)
# Generate: openssl rand -base64 32
MCP_API_KEY=
# HTTP endpoint: https://tryrevel.xyz/api/mcp
# Manifest:     https://tryrevel.xyz/api/mcp/manifest
# Local stdio:  npm run mcp

# --- Per-user export OAuth (private: each user connects their own accounts) ---
# Redirect URIs (add in each provider's app settings):
#   https://tryrevel.xyz/api/integrations/linear/callback
#   https://tryrevel.xyz/api/integrations/notion/callback
#   https://tryrevel.xyz/api/integrations/github/callback
# Encrypts per-user OAuth tokens at rest (AES-256-GCM). Required in production.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Falls back to AUTH_SECRET / NEXTAUTH_SECRET if unset (dev only).
INTEGRATIONS_ENCRYPTION_KEY=
#
# Linear OAuth app: https://linear.app/settings/api/applications/new
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
#
# Notion public integration: https://www.notion.so/my-integrations
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_TITLE_PROPERTY=Name
#
# GitHub OAuth app: https://github.com/settings/developers (scopes: gist)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
#
# Legacy shared keys (optional fallback — prefer per-user OAuth above)
# GITHUB_TOKEN=
# LINEAR_API_KEY=
# LINEAR_TEAM_ID=
# NOTION_API_KEY=
# NOTION_DATABASE_ID=


# --- NextAuth (Google OAuth + email/password) ---
# Optional: fixes some local Windows Google OAuth ConnectTimeout errors
# NODE_OPTIONS=--dns-result-order=ipv4first
# Production canonical auth host (OAuth callbacks + sign-in flow)
# Must be exactly https://auth.tryrevel.xyz (no trailing slash)
NEXTAUTH_URL=https://auth.tryrevel.xyz
AUTH_URL=https://auth.tryrevel.xyz
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Auth.js v5 auto-discovery aliases (same values as above)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Google Console redirect URIs:
#   Local dev:  http://localhost:3000/api/auth/callback/google
#   Production: https://auth.tryrevel.xyz/api/auth/callback/google

# --- Supabase (database) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma (URL-encode special chars in password) ---
DATABASE_URL=
DIRECT_URL=
# USE_PRISMA_LOCAL=true

# --- Website usage limits ---
# Max product audits per signed-in user per UTC week (Mission Control only; resets Monday 00:00 UTC)
WEEKLY_AUDIT_LIMIT=3
# Legacy alias (optional): DAILY_AUDIT_LIMIT=3

# --- Admin access (Mission Control Analytics + Partners) ---
# Comma-separated emails that always get admin (in addition to users.is_admin in DB)
REVEL_ADMIN_EMAILS=mojeeb.eth@gmail.com

# --- Partner API (platform integrations e.g. Arcapush) ---
# Partners are created in Mission Control → Partners; keys start with rvl_pk_
# REVEL_PARTNER_API_KEY=   # set on partner platform server, not Revel

# --- OKX x402 billing (marketplace + paid API) ---
# Register as ASP on OKX Onchain OS, then add API keys + wallet
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
# Seller wallet on X Layer (receives USDT0)
OKX_PAY_TO=
# Price per completed audit in USD (default 0.35; try 0.50 for listing margin)
OKX_AUDIT_PRICE_USD=0.35
# A2MCP endpoint (marketplace): POST /api/mcp with x402 PAYMENT-SIGNATURE headers
# Alternate: POST /api/audit { "url": "..." } with x402 payment headers

# --- Email (Resend) — partner approvals, API keys, sign-up welcome ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Revel <hello@mail.tryrevel.xyz>
REVEL_ADMIN_NOTIFY_EMAIL=mojeeb.eth@gmail.com

# --- Analytics (optional) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- SEO / Search Console (optional meta verification codes) ---
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=

# --- IndexNow (Bing + partners) — key file: /revel-tryrevel-indexnow.txt ---
INDEXNOW_KEY=revel-tryrevel-indexnow
INDEXNOW_SECRET=
CRON_SECRET=
# INDEXNOW_DISABLED=true