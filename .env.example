# =============================================================================
# Revel — environment variables (copy to .env.local, then to Vercel)
# =============================================================================
# Local dev:  NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://tryrevel.xyz  (https:// required on Vercel)
# Note: bare domains like tryrevel.xyz are auto-normalized to https:// at build time
# =============================================================================

# --- Site URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_SUBDOMAIN_REDIRECTS=false
NEXT_PUBLIC_DOCS_URL=https://docs.tryrevel.xyz
NEXT_PUBLIC_LEGAL_URL=https://legal.tryrevel.xyz
NEXT_PUBLIC_AUTH_URL=https://auth.tryrevel.xyz

# --- Agentic analysis (Phase 2) ---
# Groq (recommended free dev tier): https://console.groq.com/keys
GROQ_API_KEY=
# Best quality on free tier: llama-3.3-70b-versatile (parallel tool use)
# Highest volume: llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=meta-llama/llama-4-scout-17b-16e-instruct,llama-3.1-8b-instant
# groq | gemini | auto (default: groq if key present, else gemini)
ANALYSIS_PROVIDER=auto

# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Production: gemini-2.5-flash (best quality)
# Broke/dev:   gemini-2.5-flash-lite (same API, function calling, higher free quota)
GEMINI_MODEL=gemini-2.5-flash
# Optional comma-separated fallbacks when primary hits 429 (auto-includes flash-lite)
GEMINI_MODEL_FALLBACK=gemini-2.5-flash-lite
# auto = agentic when GEMINI_API_KEY is set; legacy = single-shot OpenRouter only
ANALYSIS_MODE=auto
# Each step = 1 API call; use 8 locally to stretch free quota (homepage + 2 pages + submit)
AGENT_MAX_STEPS=8
# When Gemini hits 429, auto-falls back to OpenRouter if OPENROUTER_API_KEY is set

# --- OpenRouter (legacy single-shot fallback) ---
OPENROUTER_API_KEY=
# Production (reliable, ~$0.01/run): google/gemini-2.5-flash
# Free (rate-limited): qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_MODEL=google/gemini-2.5-flash
# Optional comma-separated fallbacks if primary is busy
OPENROUTER_MODEL_FALLBACK=qwen/qwen3-next-80b-a3b-instruct:free

# --- Mission Control exports (Phase 2 — NEW, optional) ---
# >>> NEW: add all three blocks to Vercel Production after deploy
#
# NEW — GitHub Gist (private blueprint backup; classic token needs gist scope)
GITHUB_TOKEN=
#
# NEW — Linear (creates issues from Action Queue; team UUID from Linear settings)
LINEAR_API_KEY=
LINEAR_TEAM_ID=
#
# NEW — Notion (creates blueprint page; share DB with your integration)
NOTION_API_KEY=
NOTION_DATABASE_ID=
NOTION_TITLE_PROPERTY=Name

# --- NextAuth (Google OAuth + email/password) ---
# Optional: fixes some local Windows Google OAuth ConnectTimeout errors
# NODE_OPTIONS=--dns-result-order=ipv4first
# Production canonical auth host (OAuth callbacks + sign-in flow)
# Must be exactly https://auth.tryrevel.xyz (no trailing slash)
NEXTAUTH_URL=https://auth.tryrevel.xyz
AUTH_URL=https://auth.tryrevel.xyz
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Auth.js v5 auto-discovery aliases (same values as above)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Google Console redirect URIs:
#   Local dev:  http://localhost:3000/api/auth/callback/google
#   Production: https://auth.tryrevel.xyz/api/auth/callback/google

# --- Supabase (database) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma (URL-encode special chars in password) ---
DATABASE_URL=
DIRECT_URL=
# USE_PRISMA_LOCAL=true

# --- Stripe (optional — returns 503 when unset) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEVELOPER_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# --- Analytics (optional) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- SEO / Search Console (optional meta verification codes) ---
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=

# --- IndexNow (Bing + partners) — key file: /revel-tryrevel-indexnow.txt ---
INDEXNOW_KEY=revel-tryrevel-indexnow
INDEXNOW_SECRET=
CRON_SECRET=
# INDEXNOW_DISABLED=true