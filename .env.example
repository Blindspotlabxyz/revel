# =============================================================================
# Revel — environment variables (copy to .env.local, then to Vercel)
# =============================================================================
# Local dev:  NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://tryrevel.xyz  (https:// required on Vercel)
# Note: bare domains like tryrevel.xyz are auto-normalized to https:// at build time
# =============================================================================

# --- Site URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_SUBDOMAIN_REDIRECTS=false
NEXT_PUBLIC_DOCS_URL=https://docs.tryrevel.xyz
NEXT_PUBLIC_LEGAL_URL=https://legal.tryrevel.xyz
NEXT_PUBLIC_AUTH_URL=https://auth.tryrevel.xyz

# --- OpenRouter (AI analysis) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# --- NextAuth (Google OAuth + email/password) ---
# Production canonical auth host (OAuth callbacks + sign-in flow)
# Must be exactly https://auth.tryrevel.xyz (no trailing slash)
NEXTAUTH_URL=https://auth.tryrevel.xyz
AUTH_URL=https://auth.tryrevel.xyz
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google Console redirect URI: https://auth.tryrevel.xyz/api/auth/callback/google

# --- Supabase (database) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma (URL-encode special chars in password) ---
DATABASE_URL=
DIRECT_URL=
# USE_PRISMA_LOCAL=true

# --- Stripe (optional — returns 503 when unset) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEVELOPER_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# --- Analytics (optional) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- SEO / Search Console (optional meta verification codes) ---
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=

# --- IndexNow (Bing + partners) — key file: /revel-tryrevel-indexnow.txt ---
INDEXNOW_KEY=revel-tryrevel-indexnow
INDEXNOW_SECRET=
CRON_SECRET=
# INDEXNOW_DISABLED=true