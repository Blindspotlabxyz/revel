# Main site — https://tryrevel.xyz in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Subdomain routing (enable on production when DNS is configured)
# NEXT_PUBLIC_ENABLE_SUBDOMAIN_REDIRECTS=true
# NEXT_PUBLIC_DOCS_URL=https://docs.tryrevel.xyz
# NEXT_PUBLIC_LEGAL_URL=https://legal.tryrevel.xyz
# NEXT_PUBLIC_AUTH_URL=https://auth.tryrevel.xyz

# OpenRouter (AI analysis)
OPENROUTER_API_KEY=
# Free models that handle JSON strategy output well (pick one):
#   openai/gpt-oss-120b:free          — best default: reasoning + structured JSON
#   nvidia/nemotron-3-super-120b-a12b:free — huge context if pages are long
#   openrouter/free                   — auto-picks an available free model
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Clerk (authentication) — add https://tryrevel.xyz in Clerk Dashboard before production deploy
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/log-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Temporarily disable Clerk (e.g. iPhone preview on LAN IP) — no auth, no redirect loop
# NEXT_PUBLIC_DISABLE_CLERK=true
# iPhone on same WiFi: add http://YOUR_LAN_IP:3000 to Clerk → Allowed origins
# Or re-pull keys: clerk env pull --app app_3FzZ2S8oAI7yFCSPcy5UyRvealy

# Supabase (database)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma — transaction-mode pooler (runtime queries via Prisma Client)
# URL-encode special characters in your password (@ # / etc.)
DATABASE_URL="postgresql://postgres.xkkdbtpsqqpiywyrevkr:[YOUR-PASSWORD]@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma — session-mode pooler (migrations / prisma db pull)
DIRECT_URL="postgresql://postgres.xkkdbtpsqqpiywyrevkr:[YOUR-PASSWORD]@aws-1-eu-west-2.pooler.supabase.com:5432/postgres"

# Force Prisma locally (only if Postgres ports 5432/6543 work on your network)
# USE_PRISMA_LOCAL=true

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEVELOPER_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# Analytics (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Search indexing (optional — add after verifying in Search Console / Bing Webmaster)
# GOOGLE_SITE_VERIFICATION=
# BING_SITE_VERIFICATION=
# YANDEX_SITE_VERIFICATION=

# IndexNow (Bing + partners) — key file at /revel-tryrevel-indexnow.txt
# INDEXNOW_KEY=revel-tryrevel-indexnow
# INDEXNOW_SECRET=  # Bearer token for POST /api/indexnow after deploy